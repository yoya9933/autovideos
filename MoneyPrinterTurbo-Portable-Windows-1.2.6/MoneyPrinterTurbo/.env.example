# =============================================
# MoneyPrinterTurbo — Secrets Template
# =============================================
# Copy this file to .env and fill in the values.
# .env is ignored by git and will NOT be committed.
#
# Note: config.toml is the primary source for non-sensitive config,
# but sensitive keys are loaded from this .env file.
# =============================================

# --- Gemini (LLM) ---
GEMINI_API_KEY=

# --- YouTube Upload (OAuth 2.0) ---
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# --- Pexels (video stock footage) ---
PEXELS_API_KEY=

# --- SiliconFlow (TTS, optional) ---
SILICONFLOW_API_KEY=

# --- Azure Speech (TTS, optional) ---
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
